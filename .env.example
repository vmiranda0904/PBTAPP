# Firebase project configuration
# Create a project at https://console.firebase.google.com
# Enable Firestore Database (start in production mode)
# Then copy the project's web app credentials below.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# EmailJS configuration
# Sign up at https://www.emailjs.com and create a service + email template.
# The template must include these variables:
#   {{to_email}}       - recipient (the admin)
#   {{user_name}}      - registrant's full name
#   {{user_email}}     - registrant's email
#   {{user_position}}  - registrant's position
#   {{approve_url}}    - link to approve the account
#   {{reject_url}}     - link to reject the account
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Admin email that receives approval/rejection requests
VITE_ADMIN_EMAIL=admin@example.com

# Public URL of the deployed app (used to build approve/reject links)
VITE_APP_URL=https://vmiranda0904.github.io
