# Firebase project configuration
# Create a project at https://console.firebase.google.com
# Enable Firestore Database (start in production mode)
# Then copy the project's web app credentials below.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# EmailJS configuration
# Sign up at https://www.emailjs.com and create a service + two email templates.
#
# Admin notification template (sent when a new user registers):
#   {{to_email}}       - recipient (the admin)
#   {{user_name}}      - registrant's full name
#   {{user_email}}     - registrant's email
#   {{user_role}}      - registrant's role (Admin / Coach / Player / Parent)
#   {{approve_url}}    - link to approve the account
#   {{reject_url}}     - link to reject the account
#
# User status notification template (sent to the registrant after admin action):
#   {{to_email}}   - recipient (the registrant)
#   {{user_name}}  - registrant's full name
#   {{status}}     - "approved" or "rejected"
#   {{app_url}}    - link to the app sign-in page
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_admin_template_id
VITE_EMAILJS_USER_TEMPLATE_ID=your_emailjs_user_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Admin email — must match the email used when the admin account was registered.
# This account is automatically approved on registration (no approval step needed).
VITE_ADMIN_EMAIL=primebeachtraining@gmail.com

# Public URL of the deployed app (used to build approve/reject links)
VITE_APP_URL=https://vmiranda0904.github.io

# Firebase Cloud Messaging — VAPID key for push notifications.
# In the Firebase Console, go to Project Settings → Cloud Messaging →
# Web Push certificates → Generate key pair. Copy the "Key pair" value here.
# This is required for push notifications to work on this device.
VITE_FIREBASE_VAPID_KEY=your_firebase_vapid_key

# Supabase configuration used by the premium athlete / coach / recruiter dashboards.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_DEFAULT_ATHLETE_ID=your-default-athlete-uuid

# AI pipeline websocket endpoint. Use the base HTTP(S) or WS(S) URL; the app appends /live.
VITE_AI_PIPELINE_URL=https://your-ai-engine.example.com

# Stripe checkout configuration used by the frontend.
VITE_CHECKOUT_API_URL=/api/checkout
VITE_STRIPE_ATHLETE_PRO_PRICE_ID=price_athlete_pro
VITE_STRIPE_COACH_PRO_PRICE_ID=price_coach_pro
VITE_STRIPE_RECRUITER_PRO_PRICE_ID=price_recruiter_pro

# Optional local feature toggles for demoing unlocked subscription states.
VITE_ACTIVE_SUBSCRIPTIONS=athlete,coach,recruiter

# Server-side environment variables for the checkout handler:
# STRIPE_SECRET_KEY=sk_live_or_test
# STRIPE_SUCCESS_URL=http://localhost:5173/?checkout=success
# STRIPE_CANCEL_URL=http://localhost:5173/?checkout=cancelled
